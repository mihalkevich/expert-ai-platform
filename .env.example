# ============================================================
# AI Expert Growth Platform — Environment Variables
# Copy this file to .env.local and fill in all values.
# Never commit .env.local or any file containing real secrets.
# ============================================================

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ------------------------------------------------------------
# Database (PostgreSQL via Prisma)
# Supabase example: postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
# ------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/content_repurposer

# ------------------------------------------------------------
# NextAuth.js
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# ------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_openssl_rand_base64_32

# ------------------------------------------------------------
# OAuth — Google
# https://console.cloud.google.com/
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ------------------------------------------------------------
# OAuth — GitHub
# https://github.com/settings/developers
# ------------------------------------------------------------
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ------------------------------------------------------------
# AI — OpenAI
# https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=sk-...

# AI — Anthropic (optional, used for Claude fallback)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Default model for repurposing (gpt-4o | gpt-4o-mini | claude-3-5-sonnet-20241022)
AI_MODEL=gpt-4o

# ------------------------------------------------------------
# Stripe
# https://dashboard.stripe.com/apikeys
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (create in Stripe Dashboard → Products)
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_EXPERT=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ------------------------------------------------------------
# Social — LinkedIn
# https://www.linkedin.com/developers/apps
# ------------------------------------------------------------
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# ------------------------------------------------------------
# Social — Twitter / X (OAuth 2.0)
# https://developer.twitter.com/en/portal/dashboard
# ------------------------------------------------------------
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret

# ------------------------------------------------------------
# Social — Instagram / Facebook
# https://developers.facebook.com/apps/
# ------------------------------------------------------------
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret

# ------------------------------------------------------------
# Email (Resend)
# https://resend.com/api-keys
# ------------------------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@contentrepurposer.com

# ------------------------------------------------------------
# Storage (Uploadthing / S3-compatible)
# ------------------------------------------------------------
UPLOADTHING_SECRET=sk_live_...
UPLOADTHING_APP_ID=your_uploadthing_app_id

# AWS S3 (alternative to Uploadthing)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# ------------------------------------------------------------
# Queue (Redis / BullMQ)
# Upstash example: rediss://default:<password>@<host>.upstash.io:6380
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------
# Voice cloning (ElevenLabs — optional)
# https://elevenlabs.io/
# ------------------------------------------------------------
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# ------------------------------------------------------------
# Analytics (PostHog — optional)
# ------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ------------------------------------------------------------
# Monitoring (Sentry — optional)
# ------------------------------------------------------------
SENTRY_DSN=https://...@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0
SENTRY_ORG=your-org
SENTRY_PROJECT=content-repurposer
