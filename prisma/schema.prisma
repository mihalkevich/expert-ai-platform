// AI Expert Growth Platform - Full Prisma Schema
// Provider: PostgreSQL

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum PlanStatus {
  FREE
  PRO
  EXPERT
  BUSINESS
  ENTERPRISE
}

enum Platform {
  LINKEDIN
  TWITTER
  INSTAGRAM
  NEWSLETTER
  BLOG
}

enum InputType {
  RAW_TEXT
  BLOG_URL
  YOUTUBE_URL
  AUDIO_UPLOAD
  VIDEO_UPLOAD
}

enum JobStatus {
  PENDING
  EXTRACTING
  GENERATING
  COMPLETED
  FAILED
  PARTIALLY_FAILED
}

enum InboxItemType {
  COMMENT
  DM
  MENTION
}

enum InboxItemStatus {
  NEW
  AI_DRAFTED
  REPLIED
  IGNORED
}

enum AvatarKnowledgeType {
  FAQ
  PRODUCT
  BIO
  CUSTOM
}

enum AiEmployeeRole {
  AMBASSADOR
  SALES
  SUPPORT
  THOUGHT_LEADER
}

enum EmployeeContentType {
  PERSONAL
  PROFESSIONAL
  PROMOTIONAL
}

enum TeamMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum ChallengeStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum ChallengeDayStatus {
  PENDING
  DRAFTED
  PUBLISHED
  SKIPPED
}

enum MonitoredPostStatus {
  PENDING
  COMMENTED
  SKIPPED
  FAILED
}

// ─────────────────────────────────────────────
// AUTH (NextAuth compatible)
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Billing
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  planStatus           PlanStatus @default(FREE)

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Voice
  voiceProfiles VoiceProfile[]

  // Repurpose
  repurposeJobs RepurposeJob[]

  // Social
  socialAccounts SocialAccount[]

  // Inbox
  inboxItems     InboxItem[]
  autoReplyRules AutoReplyRule[]

  // Reputation
  topicMonitors     TopicMonitor[]
  reputationMetrics ReputationMetric[]

  // Challenges
  challenges Challenge[]

  // AI Avatar
  aiAvatars AiAvatar[]

  // AI Employees
  companyProfile  CompanyProfile?
  aiEmployees     AiEmployee[]

  // Analytics
  accountMetrics AccountMetric[]
  weeklyDigests  WeeklyDigest[]

  // Billing
  usageRecords UsageRecord[]
  apiKeys      ApiKey[]
  teamMembers  TeamMember[]

  @@index([email])
  @@index([stripeCustomerId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// VOICE
// ─────────────────────────────────────────────

model VoiceProfile {
  id                 String   @id @default(cuid())
  userId             String
  name               String
  industry           String?
  targetAudience     String?
  customInstructions String?
  sampleTexts        String[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Tone sliders (0-100)
  formalityCasual   Int @default(50)
  seriousFun        Int @default(50)
  technicalSimple   Int @default(50)
  conciseVerbose    Int @default(50)

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  repurposeJobs RepurposeJob[]

  @@index([userId])
  @@map("voice_profiles")
}

// ─────────────────────────────────────────────
// REPURPOSE
// ─────────────────────────────────────────────

model RepurposeJob {
  id              String    @id @default(cuid())
  userId          String
  voiceProfileId  String?
  inputType       InputType
  inputContent    String?
  inputUrl        String?
  inputFileKey    String?
  extractedText   String?
  targetPlatforms Platform[]
  status          JobStatus @default(PENDING)
  errorMessage    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  completedAt     DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceProfile VoiceProfile? @relation(fields: [voiceProfileId], references: [id], onDelete: SetNull)
  outputs      Output[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@map("repurpose_jobs")
}

// ─────────────────────────────────────────────
// OUTPUT
// ─────────────────────────────────────────────

model Output {
  id            String   @id @default(cuid())
  repurposeJobId String
  platform      Platform
  content       String
  editedContent String?
  isEdited      Boolean  @default(false)
  charCount     Int      @default(0)
  version       Int      @default(1)
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  repurposeJob RepurposeJob @relation(fields: [repurposeJobId], references: [id], onDelete: Cascade)
  postMetrics  PostMetric[]

  @@index([repurposeJobId])
  @@index([platform])
  @@map("outputs")
}

// ─────────────────────────────────────────────
// SOCIAL
// ─────────────────────────────────────────────

model SocialAccount {
  id               String   @id @default(cuid())
  userId           String
  platform         Platform
  platformUserId   String
  username         String?
  avatarUrl        String?
  tokens           Json     @default("{}")
  isActive         Boolean  @default(true)
  connectedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  inboxItems             InboxItem[]
  monitoredPosts         MonitoredPost[]
  accountMetrics         AccountMetric[]
  employeeSocialAccounts EmployeeSocialAccount[]

  @@unique([userId, platform, platformUserId])
  @@index([userId])
  @@index([platform])
  @@map("social_accounts")
}

// ─────────────────────────────────────────────
// INBOX
// ─────────────────────────────────────────────

model InboxItem {
  id              String          @id @default(cuid())
  userId          String
  socialAccountId String?
  type            InboxItemType
  status          InboxItemStatus @default(NEW)
  sentiment       String?
  priority        Int             @default(0)
  platformItemId  String?
  authorName      String?
  authorHandle    String?
  authorAvatarUrl String?
  content         String
  aiDraftReply    String?
  repliedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, status])
  @@index([userId, type])
  @@map("inbox_items")
}

model AutoReplyRule {
  id              String   @id @default(cuid())
  userId          String
  name            String
  isActive        Boolean  @default(true)
  triggerKeywords String[]
  platform        Platform?
  replyTemplate   String
  tone            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auto_reply_rules")
}

// ─────────────────────────────────────────────
// REPUTATION
// ─────────────────────────────────────────────

model TopicMonitor {
  id          String   @id @default(cuid())
  userId      String
  name        String
  keywords    String[]
  niche       String?
  commentTone String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  monitoredPosts MonitoredPost[]

  @@index([userId])
  @@map("topic_monitors")
}

model MonitoredPost {
  id              String              @id @default(cuid())
  topicMonitorId  String
  socialAccountId String?
  platformPostId  String?
  platform        Platform?
  postUrl         String?
  authorName      String?
  authorHandle    String?
  postContent     String?
  relevanceScore  Float               @default(0)
  aiComment       String?
  status          MonitoredPostStatus @default(PENDING)
  commentedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  topicMonitor  TopicMonitor   @relation(fields: [topicMonitorId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)

  @@index([topicMonitorId])
  @@index([status])
  @@map("monitored_posts")
}

model ReputationMetric {
  id              String   @id @default(cuid())
  userId          String
  platform        Platform?
  date            DateTime @default(now())
  followerCount   Int      @default(0)
  followerChange  Int      @default(0)
  mentionCount    Int      @default(0)
  commentCount    Int      @default(0)
  sentimentScore  Float    @default(0)
  topKeywords     String[]
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@map("reputation_metrics")
}

// ─────────────────────────────────────────────
// CHALLENGES
// ─────────────────────────────────────────────

model Challenge {
  id          String          @id @default(cuid())
  userId      String
  name        String
  description String?
  duration    Int
  status      ChallengeStatus @default(DRAFT)
  platforms   Platform[]
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  days         ChallengeDay[]
  backlogItems ChallengeBacklogItem[]

  @@index([userId])
  @@index([userId, status])
  @@map("challenges")
}

model ChallengeDay {
  id            String             @id @default(cuid())
  challengeId   String
  dayNumber     Int
  topic         String?
  contentDraft  String?
  status        ChallengeDayStatus @default(PENDING)
  publishedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([challengeId, dayNumber])
  @@index([challengeId])
  @@map("challenge_days")
}

model ChallengeBacklogItem {
  id          String   @id @default(cuid())
  challengeId String
  title       String
  description String?
  kanbanStatus String  @default("TODO")
  order       Int      @default(0)
  platform    Platform?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@index([challengeId])
  @@map("challenge_backlog_items")
}

// ─────────────────────────────────────────────
// AI AVATAR
// ─────────────────────────────────────────────

model AiAvatar {
  id          String   @id @default(cuid())
  userId      String
  name        String
  greeting    String?
  boundaries  String?
  isActive    Boolean  @default(false)
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledge     AvatarKnowledge[]
  conversations AvatarConversation[]

  @@index([userId])
  @@map("ai_avatars")
}

model AvatarKnowledge {
  id         String              @id @default(cuid())
  avatarId   String
  type       AvatarKnowledgeType
  title      String?
  content    String
  isActive   Boolean             @default(true)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  avatar AiAvatar @relation(fields: [avatarId], references: [id], onDelete: Cascade)

  @@index([avatarId])
  @@index([avatarId, type])
  @@map("avatar_knowledge")
}

model AvatarConversation {
  id          String   @id @default(cuid())
  avatarId    String
  visitorId   String?
  visitorName String?
  messages    Json     @default("[]")
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  createdAt   DateTime @default(now())

  avatar AiAvatar @relation(fields: [avatarId], references: [id], onDelete: Cascade)

  @@index([avatarId])
  @@map("avatar_conversations")
}

// ─────────────────────────────────────────────
// AI EMPLOYEES
// ─────────────────────────────────────────────

model CompanyProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  companyName       String
  industry          String?
  products          Json     @default("[]")
  brandGuidelines   String?
  complianceRules   String?
  website           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiEmployees AiEmployee[]

  @@map("company_profiles")
}

model AiEmployee {
  id               String         @id @default(cuid())
  userId           String
  companyProfileId String?
  name             String
  role             AiEmployeeRole
  personality      Json           @default("{}")
  background       Json           @default("{}")
  writingStyle     Json           @default("{}")
  avatarUrl        String?
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyProfile   CompanyProfile?         @relation(fields: [companyProfileId], references: [id], onDelete: SetNull)
  socialAccounts   EmployeeSocialAccount[]
  contentPlans     EmployeeContentPlan[]

  @@index([userId])
  @@index([userId, role])
  @@map("ai_employees")
}

model EmployeeSocialAccount {
  id               String   @id @default(cuid())
  aiEmployeeId     String
  socialAccountId  String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  aiEmployee    AiEmployee    @relation(fields: [aiEmployeeId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@unique([aiEmployeeId, socialAccountId])
  @@index([aiEmployeeId])
  @@map("employee_social_accounts")
}

model EmployeeContentPlan {
  id           String              @id @default(cuid())
  aiEmployeeId String
  title        String
  contentType  EmployeeContentType @default(PROFESSIONAL)
  content      String?
  platform     Platform?
  scheduledAt  DateTime?
  publishedAt  DateTime?
  status       String              @default("DRAFT")
  metadata     Json                @default("{}")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  aiEmployee    AiEmployee     @relation(fields: [aiEmployeeId], references: [id], onDelete: Cascade)
  campaignPosts CampaignPost[]

  @@index([aiEmployeeId])
  @@index([aiEmployeeId, status])
  @@map("employee_content_plans")
}

model PromoCampaign {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  platforms   Platform[]
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  status      String   @default("DRAFT")
  goals       Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts CampaignPost[]

  @@index([userId])
  @@map("promo_campaigns")
}

model CampaignPost {
  id                    String   @id @default(cuid())
  promoCampaignId       String
  employeeContentPlanId String?
  platform              Platform?
  content               String?
  scheduledAt           DateTime?
  publishedAt           DateTime?
  status                String   @default("DRAFT")
  platformPostId        String?
  metrics               Json     @default("{}")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  promoCampaign       PromoCampaign        @relation(fields: [promoCampaignId], references: [id], onDelete: Cascade)
  employeeContentPlan EmployeeContentPlan? @relation(fields: [employeeContentPlanId], references: [id], onDelete: SetNull)

  @@index([promoCampaignId])
  @@map("campaign_posts")
}

// ─────────────────────────────────────────────
// ANALYTICS
// ─────────────────────────────────────────────

model AccountMetric {
  id              String    @id @default(cuid())
  userId          String
  socialAccountId String?
  platform        Platform?
  date            DateTime
  followerCount   Int       @default(0)
  followerGain    Int       @default(0)
  impressions     Int       @default(0)
  reach           Int       @default(0)
  profileViews    Int       @default(0)
  engagementRate  Float     @default(0)
  createdAt       DateTime  @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)

  @@unique([userId, platform, date])
  @@index([userId])
  @@index([userId, date])
  @@map("account_metrics")
}

model PostMetric {
  id             String    @id @default(cuid())
  outputId       String?
  platformPostId String?
  platform       Platform?
  date           DateTime
  impressions    Int       @default(0)
  reach          Int       @default(0)
  likes          Int       @default(0)
  comments       Int       @default(0)
  shares         Int       @default(0)
  saves          Int       @default(0)
  clicks         Int       @default(0)
  engagementRate Float     @default(0)
  createdAt      DateTime  @default(now())

  output Output? @relation(fields: [outputId], references: [id], onDelete: SetNull)

  @@index([outputId])
  @@index([platform, date])
  @@map("post_metrics")
}

model WeeklyDigest {
  id              String   @id @default(cuid())
  userId          String
  weekStartDate   DateTime
  weekEndDate     DateTime
  totalPosts      Int      @default(0)
  totalImpressions Int     @default(0)
  totalEngagements Int     @default(0)
  followerGrowth  Int      @default(0)
  topPerformingPlatform Platform?
  insights        Json     @default("{}")
  recommendations String[]
  sentAt          DateTime?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStartDate])
  @@index([userId])
  @@map("weekly_digests")
}

// ─────────────────────────────────────────────
// BILLING
// ─────────────────────────────────────────────

model UsageRecord {
  id          String   @id @default(cuid())
  userId      String
  feature     String
  quantity    Int      @default(1)
  metadata    Json     @default("{}")
  recordedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, feature])
  @@index([userId, recordedAt])
  @@map("usage_records")
}

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  keyHash     String    @unique
  keyPrefix   String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  permissions String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  avatarUrl   String?
  planStatus  PlanStatus @default(FREE)
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  stripePriceId        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members TeamMember[]

  @@index([slug])
  @@map("teams")
}

model TeamMember {
  id        String         @id @default(cuid())
  teamId    String
  userId    String
  role      TeamMemberRole @default(MEMBER)
  joinedAt  DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@map("team_members")
}
